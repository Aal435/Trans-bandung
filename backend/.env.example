# Backend Environment Variables
# Note: Copy and rename to .env in backend directory, then update values

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=trans_bandung
DB_PORT=3306

# JWT Configuration
JWT_SECRET=transbandung_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# AWS S3 Configuration
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=trans-bandung-files
CLOUDFRONT_DOMAIN=your_cloudfront_domain_here

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
